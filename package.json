{
  "name": "kinetic-enterprise-backend",
  "version": "1.1.0",
  "description": "Kinetic v1.1 Enterprise — Audit, Compliance & Security Backend",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --coverage --runInBand",
    "test:unit": "jest src/audit/tests.js src/crypto/tests.js --coverage",
    "test:integration": "jest src/tests/integration.js --runInBand --forceExit",
    "migrate": "node -e \"require('./src/audit/db').runMigrations().then(() => process.exit(0))\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5"
  },
  "optionalDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.490.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "coveragePathIgnorePatterns": ["/node_modules/"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
