{
  "name": "kinetic-enterprise-backend",
  "version": "1.1.0",
  "description": "Kinetic v1.1 Enterprise — Audit, Compliance & Security Backend",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --coverage --runInBand",
    "test:unit": "jest src/audit/tests.js src/crypto/tests.js --coverage",
    "test:integration": "jest src/tests/integration.js --runInBand --forceExit",
    "migrate": "node -e \"require('./src/audit/db').runMigrations().then(() => process.exit(0))\"",
    "start:frontend": "react-scripts start",
    "build:frontend": "react-scripts build",
    "test:frontend": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "@vercel/speed-insights": "^1.0.2"
  },
  "optionalDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.490.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
